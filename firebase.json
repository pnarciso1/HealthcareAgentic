{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": [
    {
      "target": "live",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        { "source": "/medbills", "destination": "/mycareclaim/medbills", "type": 301 },
        { "source": "/medbills/", "destination": "/mycareclaim/medbills", "type": 301 }
      ],
      "rewrites": [
        {
          "source": "/resources",
          "destination": "/resources.html"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "/articles-data.json",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        }
      ]
    },
    {
      "target": "agent1-chat-improvements",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "redirects": [
        { "source": "/medbills", "destination": "/mycareclaim/medbills", "type": 301 },
        { "source": "/medbills/", "destination": "/mycareclaim/medbills", "type": 301 }
      ],
      "rewrites": [
        {
          "source": "/resources",
          "destination": "/resources.html"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ],
      "headers": [
        {
          "source": "/articles-data.json",
          "headers": [
            {
              "key": "Cache-Control",
              "value": "no-cache"
            }
          ]
        }
      ]
    }
  ]
}
