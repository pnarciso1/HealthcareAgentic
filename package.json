{
  "name": "healthcare-agentic",
  "version": "8.0.0",
  "description": "AI-powered healthcare billing and insurance assistance platform with unified Team Tabs navigation",
  "scripts": {
    "generate-articles": "python generate_articles_advanced.py",
    "generate-articles-simple": "python generate_articles.py",
    "build": "npm run generate-articles && firebase deploy",
    "dev": "firebase serve",
    "deploy": "firebase deploy",
    "validate-articles": "python -c \"from generate_articles_advanced import ArticleGenerator; ArticleGenerator('public/article-template.html', 'public/articles-data.json', 'public/resources').generate_articles()\""
  },
  "dependencies": {
    "markdown": "^3.4.0"
  },
  "devDependencies": {
    "firebase-tools": "^12.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
} 