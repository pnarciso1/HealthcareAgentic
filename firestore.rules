rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isValidDisputeStatus(status) {
      return status in [
        'draft',
        'submitted',
        'in_review',
        'awaiting_response',
        'resolved_adjusted',
        'resolved_denied',
        'closed',
        'escalated',
        'appealed'
      ];
    }
    
    function hasStatusField(data) {
      return data.keys().hasAny(['status']);
    }
    
    // ========================================
    // USER DATA PROTECTION RULES
    // ========================================
    
    // User data access is handled by the specific rules below
    
    // ========================================
    // SPECIFIC COLLECTION RULES
    // ========================================
    
    // Document Q&A History - users can only access their own
    match /document_qa_history/{documentId} {
      allow read, write: if request.auth != null && 
        resource.data.user_id == request.auth.uid;
    }
    
    // ========================================
    // SECURITY VALIDATIONS
    // ========================================
    
    // User documents - simplified rules for core functionality
    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false; // Never allow deletion of user documents
    }
    
    // Validate analyses data structure
    match /users/{userId}/analyses/{analysisId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      
      allow create: if request.auth != null && 
        request.auth.uid == userId &&
        request.resource.data.keys().hasAll(['original_filename', 'status']) &&
        request.resource.data.original_filename is string &&
        request.resource.data.status in ['pending', 'processing', 'completed', 'failed'];
      
      allow update: if request.auth != null && 
        request.auth.uid == userId &&
        request.resource.data.status in ['pending', 'processing', 'completed', 'failed'];
    }
    
    // Validate chat history data structure
    match /users/{userId}/chat_history/{chatId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      
      allow create: if request.auth != null && 
        request.auth.uid == userId &&
        request.resource.data.keys().hasAll(['question', 'answer']) &&
        request.resource.data.question is string &&
        request.resource.data.answer is string;
    }
    
    // Validate disputes data structure
    match /users/{userId}/disputes/{disputeId} {
      allow create: if request.auth != null && 
        request.auth.uid == userId &&
        request.resource.data.keys().hasAll(['document_id', 'error_type', 'status']) &&
        request.resource.data.error_type is string &&
        isValidDisputeStatus(request.resource.data.status);
      
      allow update: if request.auth != null && 
        request.auth.uid == userId &&
        (!hasStatusField(request.resource.data) || isValidDisputeStatus(request.resource.data.status));
    }

    match /users/{userId}/disputes/{disputeId}/activity/{activityId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      
      allow create: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.data.keys().hasAll(['type', 'message', 'actor', 'created_at']) &&
        request.resource.data.type is string &&
        request.resource.data.message is string &&
        request.resource.data.actor is string &&
        request.resource.data.created_at is timestamp;
    }

    // Case billing records - allow users to read their own case information
    match /users/{userId}/cases/{caseId} {
      allow read: if request.auth != null && request.auth.uid == userId;
    }
    
    // ========================================
    // DATA INTEGRITY RULES
    // ========================================
    
    // Note: Document ID validation is handled in the specific collection rules above
    
    // ========================================
    // AUDIT AND COMPLIANCE RULES
    // ========================================
    
    // Note: Timestamp validation is handled in the specific collection rules above
    
    // ========================================
    // EMERGENCY ACCESS CONTROL
    // ========================================
    
    // Emergency lockdown rule (uncomment in case of security breach)
    // match /{document=**} {
    //   allow read, write: if false; // Deny all access
    // }
    
    // ========================================
    // DEFAULT DENY RULE
    // ========================================
    
    // By default, deny all access to any document not explicitly allowed
    // NOTE: This rule must come AFTER all specific rules to avoid conflicts
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
